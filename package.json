{
  "name": "career-crox-cc26-crm-android-live-dialer-team-chat-stable-sync",
  "private": true,
  "version": "1.0.26",
  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "scripts": {
    "render-build": "npm ci --prefix backend --omit=optional --registry=https://registry.npmjs.org/ && node scripts/render-prepare.mjs",
    "build": "npm run render-build",
    "start": "npm start --prefix backend",
    "start:render": "npm start --prefix backend",
    "local:setup": "npm install --prefix backend && npm install --prefix frontend",
    "local:backend": "npm run dev --prefix backend",
    "local:frontend": "npm run dev --prefix frontend"
  }
}
